# Console-specific env vars. Copy this file to apps/console/.env.local
# and fill in the values from your repo-root .env.local (or Supabase
# Studio → Project Settings → API).
#
# Next.js loads .env.local from each workspace's directory, not the
# repo root, so these need to be duplicated here for local dev.

# Supabase project URL — the https://*.supabase.co address.
NEXT_PUBLIC_SUPABASE_URL=

# Anon key for the browser-side Supabase Auth client. Safe to expose.
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Service-role key for server-side data reads (bypasses RLS). NEVER
# expose to the browser. This key is what lets the console read every
# audit, submission, and api_calls row regardless of policies.
SUPABASE_SERVICE_ROLE_KEY=
