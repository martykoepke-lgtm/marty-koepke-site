# ============================================================================
# Practical Informatics — environment variables
# ----------------------------------------------------------------------------
# Copy to .env.local and fill in real values. NEVER commit .env.local.
# Hard-set spend caps in EVERY vendor dashboard before pasting keys here.
# Production values live in Vercel env vars, not here.
# ============================================================================

# ---- Public site ----------------------------------------------------------
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ---- LLM providers (currently wired in lib/avi/llm-providers/) -----------
# Names below match what the code actually reads.
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GOOGLE_API_KEY=

# ---- LLM providers (planned, not yet wired) -------------------------------
# Add when the Perplexity adapter is implemented per AVI_BUILD_PLAN.md Phase 4.
PERPLEXITY_API_KEY=

# ---- Database (Supabase, currently wired in lib/supabase.ts) -------------
NEXT_PUBLIC_SUPABASE_URL=
# Service role: server-side only. NEVER prefix with NEXT_PUBLIC_.
# The AVI app uses service-role-only access — customers don't authenticate
# to Supabase directly. RLS still enforced server-side per migration policies.
SUPABASE_SERVICE_ROLE_KEY=

# ---- Stripe (currently wired in lib/links.ts as fallback-to-/contact) ----
# Public payment-link URLs. Safe to expose via NEXT_PUBLIC_ — they're URLs,
# not API keys.
NEXT_PUBLIC_STRIPE_PAYMENT_LINK_REPORT=
NEXT_PUBLIC_STRIPE_PAYMENT_LINK_SPRINT=

# ---- Stripe (planned, server-side webhook handler) -----------------------
# Add when /api/webhooks/stripe is built per AVI_BUILD_PLAN.md Phase 2.
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# ---- Email (Resend, planned) ---------------------------------------------
# Transactional: order confirms, report delivery, internal alerts.
RESEND_API_KEY=
RESEND_FROM_ADDRESS="Practical Informatics <hello@practicalinformatics.com>"
ALERT_TO_ADDRESS=mkoepkeci@gmail.com  # who gets new-order alerts

# ---- Lead nurture (Kit / ConvertKit, planned) ----------------------------
# Free-flow email gate + tier-tagged sequences. Creator tier $25/mo.
KIT_API_KEY=
KIT_API_SECRET=
KIT_FORM_ID=

# ---- Background jobs (Inngest, planned) ----------------------------------
# Async paid pipeline + scheduled drift monitoring.
INNGEST_EVENT_KEY=
INNGEST_SIGNING_KEY=

# ---- Web search corroboration (Tavily, planned) --------------------------
# ~$0.005/search, 1k free/mo. Used for D2/D6 entity corroboration.
TAVILY_API_KEY=

# ---- Google AIO (SerpAPI, optional — deferred for v1) --------------------
# $75/mo for 5k searches. Defer per AVI_BUILD_PLAN.md §7.
SERPAPI_API_KEY=

# ---- Abuse mitigation (planned, on /api/scan) ----------------------------
# Cloudflare Turnstile: free. CAPTCHA on the URL-only scan form.
TURNSTILE_SITE_KEY=
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# Upstash Rate Limit (Redis): free tier. IP rate limit on /api/scan.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# ---- AVI ops monitor (see AVI_OPS_MONITOR.md) ----------------------------
# Monthly spend caps in USD per provider. The hourly threshold-check cron
# compares month-to-date spend against these. 80% triggers a HEADS-UP
# subject prefix on the next weekly email; 95% triggers an immediate
# out-of-band alert email.
#
# These MUST match (or be safely below) what you've configured in each
# vendor's dashboard. The cap here is the monitor's view of the world —
# the vendor's hard cap is the actual ceiling.
SPEND_CAP_ANTHROPIC=25
SPEND_CAP_OPENAI=25
SPEND_CAP_PERPLEXITY=10
SPEND_CAP_TAVILY=20
# Gemini is on the free tier (rate-limited, no $ cost). Leave at 0 to
# disable cost tracking for it; the wrapper still logs the call count.
SPEND_CAP_GEMINI=0
# Resend free tier (3,000 emails/mo). Informational only; the monitor
# warns on count, not cost. Leave at 0.
SPEND_CAP_RESEND=0

# Thresholds. Override if you want different trigger points.
SPEND_ALERT_THRESHOLD_HEADS_UP=0.80
SPEND_ALERT_THRESHOLD_URGENT=0.95

# Timezone used for human-readable times in the weekly summary email body.
# The cron schedule itself is in UTC (set in vercel.json). This is just
# for display formatting in the email.
CRON_TIMEZONE=America/Los_Angeles

# Secret for authorizing Vercel Cron requests against /api/cron/*.
# Generate with: openssl rand -hex 32
# (or any long random string — keep it secret like an API key).
# Vercel sets the same value in production env; cron requests come with
# `Authorization: Bearer ${CRON_SECRET}`.
CRON_SECRET=

# ---- Operational toggles -------------------------------------------------
# Set to '1' to enable the paid pipeline once built. Leave blank in dev
# until ready.
AVI_PAID_PIPELINE_ENABLED=
# Rubric version stamped on every audit row. Bump when rubric prompts change.
AVI_RUBRIC_VERSION=v1.0-legacy
