{
  "$schema": "https://turborepo.com/schema.json",
  "ui": "tui",
  "globalEnv": [
    "NODE_ENV",
    "VERCEL",
    "VERCEL_ENV",
    "VERCEL_URL"
  ],
  "tasks": {
    "dev": {
      "cache": false,
      "persistent": true
    },
    "build": {
      "dependsOn": ["^build"],
      "outputs": [".next/**", "!.next/cache/**", "dist/**"],
      "env": [
        "NEXT_PUBLIC_SITE_URL",
        "NEXT_PUBLIC_SUPABASE_URL",
        "NEXT_PUBLIC_SUPABASE_ANON_KEY",
        "SUPABASE_SERVICE_ROLE_KEY",
        "OPENAI_API_KEY",
        "ANTHROPIC_API_KEY",
        "GOOGLE_API_KEY",
        "PERPLEXITY_API_KEY",
        "TAVILY_API_KEY",
        "RESEND_API_KEY",
        "RESEND_FROM_ADDRESS",
        "ALERT_TO_ADDRESS",
        "KIT_API_KEY",
        "KIT_API_SECRET",
        "KIT_FORM_ID",
        "INNGEST_EVENT_KEY",
        "INNGEST_SIGNING_KEY",
        "SERPAPI_API_KEY",
        "TURNSTILE_SITE_KEY",
        "NEXT_PUBLIC_TURNSTILE_SITE_KEY",
        "TURNSTILE_SECRET_KEY",
        "UPSTASH_REDIS_REST_URL",
        "UPSTASH_REDIS_REST_TOKEN",
        "SPEND_CAP_ANTHROPIC",
        "SPEND_CAP_OPENAI",
        "SPEND_CAP_PERPLEXITY",
        "SPEND_CAP_TAVILY",
        "SPEND_CAP_GEMINI",
        "SPEND_CAP_RESEND",
        "SPEND_ALERT_THRESHOLD_HEADS_UP",
        "SPEND_ALERT_THRESHOLD_URGENT",
        "CRON_TIMEZONE",
        "CRON_SECRET",
        "AVI_PAID_PIPELINE_ENABLED",
        "AVI_RUBRIC_VERSION",
        "NEXT_PUBLIC_STRIPE_PAYMENT_LINK_AUDIT",
        "NEXT_PUBLIC_STRIPE_PAYMENT_LINK_OPTIMIZATIONS",
        "NEXT_PUBLIC_STRIPE_PAYMENT_LINK_MONITORING",
        "STRIPE_SECRET_KEY",
        "STRIPE_WEBHOOK_SECRET"
      ]
    },
    "lint": {
      "dependsOn": ["^lint"]
    },
    "typecheck": {
      "dependsOn": ["^typecheck"]
    },
    "audit": {
      "cache": false
    }
  }
}
